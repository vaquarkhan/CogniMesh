# CogniMesh local development
# Copy to .env for overrides — if .env is missing, the API loads .env.example automatically.
# Use: cp .env.example .env  then  npm run dev:api  or  npm run start:dev

# --- Required for local dev (no Java / no Spring catalog) ---
AUTH_DISABLED=true
PORT=4000
CATALOG_URL=http://localhost:8080
# In-memory catalog when Spring catalog is offline (aliases: memory, embedded, true)
CATALOG_STORAGE=memory
CATALOG_FALLBACK=embedded
# Portal dev (Vite default port is 3000 in portal/vite.config.js — not 5173)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173
# CORS_ORIGIN_SUFFIXES=.cloudfront.net

# --- Security (API gateway) ---
# CSRF checks browser Origin against CORS_ORIGINS on POST/PUT/PATCH/DELETE
# CSRF_DISABLED=true
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=120
# API_BODY_LIMIT=512kb

# --- Steward deploy gate (optional) ---
# When true, Deploy queues for steward approval (Steward → Approvals panel)
# DEPLOY_APPROVAL_REQUIRED=true

# --- Observability & alerting (optional) ---
# OpenTelemetry SDK (HTTP + Express auto-instrumentation when enabled)
# OTEL_SDK_ENABLED=true
# OTEL_SERVICE_NAME=cognimesh-api-gateway
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_TRACES_EXPORTER=console
# OTEL_SDK_DISABLED=true
# ENABLE_EMF_METRICS=true
# COGNIMESH_METRICS_NAMESPACE=CogniMesh
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# ALERT_WEBHOOK_FORMAT=slack
# PAGERDUTY_ROUTING_KEY=

# --- Portal (Vite) ---
# VITE_API_URL=http://localhost:4000
# Dev server runs on http://localhost:3000 (see portal/vite.config.js)

# --- Platform operations (optional) ---
# PLATFORM_STORE=file
# PLATFORM_STORE=dynamodb
# PLATFORM_DYNAMODB_TABLE=cognimesh-prod-platform-state
# PLATFORM_DATA_DIR=data
# Live source sampling (API server only — restart after changing)
# DATA_PREVIEW_LIVE=true
# PIPELINE_VERSIONS_PATH=data/pipeline-versions.json
# COPILOT_LLM_ENABLED=true
# COPILOT_BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
# Amazon Q Business for fix guides and operations copilot (preferred when set)
# AMAZON_Q_FIX_ENABLED=true
# AMAZON_Q_APPLICATION_ID=your-q-business-app-id
# AMAZON_Q_REGION=us-east-1
# AMAZON_Q_USER_ID=cognimesh-portal
# DATA_PREVIEW_JDBC=true
# AWS_RDS_CLUSTER_ARN=arn:aws:rds:...
# AWS_RDS_SECRET_ARN=arn:aws:secretsmanager:...
# DATA_PREVIEW_ATHENA=true
# ATHENA_OUTPUT_LOCATION=s3://your-bucket/athena-results/
# AWS_IMPORT_ENABLED=true
# AWS_AGENT_DEPLOY_ENABLED=true
# (optional — real deploy also auto-enables when AWS_BEDROCK_AGENT_ROLE_ARN is set on the API)
# AWS_BEDROCK_AGENT_ROLE_ARN=arn:aws:iam::ACCOUNT:role/bedrock-agent-role

# --- AWS pipeline deploy (optional — set after terraform apply) ---
# Without these, deploy compiles locally + PVDM simulation; aws.deployed stays false
# AWS_DEPLOY_ENABLED=true
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
# AWS_STEP_FUNCTIONS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/cognimesh-prod-pipeline-orchestrator
# CHECKPOINT_BUCKET_NAME=cognimesh-dev-checkpoints-ACCOUNT
# PROOF_BUCKET_NAME=cognimesh-dev-proofs-ACCOUNT
# VAQUAR_DOMAIN_WRITER_ARN=arn:aws:lambda:us-east-1:ACCOUNT:function:cognimesh-dev-domain-writer:live
# INTEGRITY_GATE_FUNCTION=cognimesh-dev-integrity-gate
# AWS_NAME_PREFIX=cognimesh-prod
# AWS_DEPLOY_EXECUTE=false

# --- Cognito (production — disable AUTH_DISABLED) ---
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
